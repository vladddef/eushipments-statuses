{
  "name": "eushipments",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:trace": "node --trace-deprecation -r tsconfig-paths/register -r ts-node/register src/main.ts",
    "start:prod": "node dist/main",
    "deploy": "npm run build && pm2 start ecosystem.config.js",
    "deploy:reload": "npm run build && pm2 reload ecosystem.config.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "ts-node -P tsconfig.migration.json -r tsconfig-paths/register ./node_modules/typeorm/cli migration:generate -d src/data-source.ts",
    "migration:run": "ts-node -P tsconfig.migration.json -r tsconfig-paths/register ./node_modules/typeorm/cli migration:run -d src/data-source.ts",
    "migration:revert": "ts-node -P tsconfig.migration.json -r tsconfig-paths/register ./node_modules/typeorm/cli migration:revert -d src/data-source.ts"
  },
  "dependencies": {
    "@adminjs/express": "^5.1.0",
    "@adminjs/nestjs": "^5.1.1",
    "@adminjs/typeorm": "^3.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.0",
    "adminjs": "^6.8.7",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "express-formidable": "^1.2.0",
    "express-session": "^1.19.0",
    "joi": "^18.0.2",
    "nestjs-telegraf": "^2.9.1",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "telegraf": "^4.16.3",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
